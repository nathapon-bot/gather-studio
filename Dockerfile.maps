FROM nginx:alpine

# Copy our custom office map files
COPY maps/ /usr/share/nginx/html/

# Allow CORS for map files (required by WorkAdventure)
RUN printf 'server {\n\
    listen 80;\n\
    root /usr/share/nginx/html;\n\
    location / {\n\
        add_header Access-Control-Allow-Origin *;\n\
        add_header Cache-Control "no-cache";\n\
        try_files $uri $uri/ =404;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80
